# ORACLE environment configuration
# Copy this file to .env and fill in your keys
# !! Do not commit .env or share keys to public !!

# Anthropic API key for the agent reasoning loop
# Create yours here: https://console.anthropic.com/settings/keys (required)
ANTHROPIC_API_KEY=

# NCBI API key - raises BLAST rate limit from 3 to 10 requests/second
# Register free here: https://www.ncbi.nlm.nih.gov/account/ (required)
NCBI_API_KEY=